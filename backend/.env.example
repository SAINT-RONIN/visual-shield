# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=visual_shield
MYSQL_USER=vs_user
MYSQL_PASSWORD=vs_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

# JWT
JWT_SECRET=change-me-in-production
JWT_ISSUER=visual-shield

# CORS — '*' allows all origins (fine for local dev).
# For production set this to your frontend URL, e.g. https://your-app.com
# Accepts a single origin or a comma-separated list: https://a.com,https://b.com
CORS_ORIGIN=*

# Ports exposed on the host
NGINX_PORT=8081
PHPMYADMIN_PORT=8080
